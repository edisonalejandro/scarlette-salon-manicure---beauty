{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A beauty service offered by the salon",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "duration"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A booking made by a client",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" }
      },
      "required": ["serviceId", "date", "time", "clientName", "clientPhone"]
    },
    "GalleryItem": {
      "title": "GalleryItem",
      "description": "An image of a completed work",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Salon services"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Client bookings"
    },
    "/gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Work portfolio"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
